# -----------------------
# Build outputs
# -----------------------
# бинарники после go build
/bin/
# временные сборки
/build/
# исполняемые файлы Windows
*.exe
# временные бинарники Go (например, после go test -c)
*.out
# скомпилированные тестовые бинарники
*.test
# HTML-отчёты о покрытии (go tool cover -html)
coverage*.html

# -----------------------
# Dependency directories
# -----------------------
# папка с зависимостями Go Modules (может храниться, но часто игнорируется)
vendor/

# -----------------------
# IDE / editor settings
# -----------------------
# JetBrains IDE
.idea/
# файлы проектов IntelliJ
*.iml
# Visual Studio Code
.vscode/
# swap-файлы редакторов (например Vim)
*.swp
# резервные копии файлов редакторов
*.bak

# -----------------------
# Logs and temporary files
# -----------------------
# лог-файлы приложения
*.log
# временные файлы
*.tmp

# -----------------------
# Environment and local config
# -----------------------
# переменные окружения
.env
# локальные настройки проекта
config.local.*
